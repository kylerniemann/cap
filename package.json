{
  "name": "cap",
  "displayName": "cap",
  "description": "Foxglove extension plus local helper for historical bag scene search, snippets, camera previews, and click-to-seek results.",
  "publisher": "cap",
  "homepage": "",
  "version": "0.1.0",
  "license": "MIT",
  "main": "./dist/extension.js",
  "keywords": [
    "foxglove",
    "extension",
    "cap",
    "ros",
    "rosbag",
    "robotics",
    "autonomy",
    "telemetry",
    "visualization",
    "search"
  ],
  "scripts": {
    "build": "foxglove-extension build",
    "foxglove:prepublish": "foxglove-extension build --mode production",
    "index-bag": "node scripts/build-scene-index.mjs",
    "lint": "eslint .",
    "lint:ci": "eslint .",
    "lint:fix": "eslint --fix .",
    "local-install": "foxglove-extension install",
    "package": "foxglove-extension package",
    "pretest": "foxglove-extension pretest",
    "serve-index": "node scripts/scene-index-server.mjs"
  },
  "devDependencies": {
    "@foxglove/eslint-plugin": "2.1.0",
    "@foxglove/extension": "2.48.2",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "compressjs": "^1.0.3",
    "create-foxglove-extension": "1.3.1",
    "eslint": "9.39.4",
    "lz4js": "^0.2.0",
    "prettier": "3.8.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rosbag": "^5.0.0",
    "typescript": "5.9.3"
  }
}
