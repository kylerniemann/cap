{
  "name": "cap",
  "displayName": "cap",
  "description": "Foxglove extension for historical ROS bag and MCAP scene search, snippets, camera previews, and click-to-seek results.",
  "publisher": "cap",
  "homepage": "https://github.com/kylerniemann/cap",
  "version": "0.2.3",
  "license": "MIT",
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylerniemann/cap.git"
  },
  "bugs": {
    "url": "https://github.com/kylerniemann/cap/issues"
  },
  "keywords": [
    "foxglove",
    "extension",
    "cap",
    "ros",
    "rosbag",
    "mcap",
    "robotics",
    "autonomy",
    "telemetry",
    "visualization",
    "search"
  ],
  "scripts": {
    "build": "foxglove-extension build",
    "compat:fixtures": "node scripts/generate-compatibility-fixtures.mjs && node scripts/validate-compatibility-fixtures.mjs",
    "compat:fixtures:check": "node scripts/validate-compatibility-fixtures.mjs",
    "demo:generate": "node scripts/generate-demo-recording.mjs",
    "foxglove:prepublish": "foxglove-extension build --mode production",
    "index-bag": "node scripts/build-scene-index.mjs",
    "index-recording": "node scripts/build-scene-index.mjs",
    "lint": "eslint .",
    "lint:ci": "eslint .",
    "lint:fix": "eslint --fix .",
    "local-install": "foxglove-extension install",
    "package": "foxglove-extension package",
    "pretest": "foxglove-extension pretest",
    "smoke": "npm run lint && npm run compat:fixtures:check && npm run package",
    "serve-index": "node scripts/scene-index-server.mjs"
  },
  "devDependencies": {
    "@foxglove/eslint-plugin": "2.1.0",
    "@foxglove/extension": "2.48.2",
    "@foxglove/ros2idl-parser": "^0.3.6",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "compressjs": "^1.0.3",
    "create-foxglove-extension": "1.3.1",
    "eslint": "9.39.4",
    "lz4js": "^0.2.0",
    "prettier": "3.8.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rosbag": "^5.0.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@foxglove/ros2idl-parser": "^0.3.6",
    "@foxglove/rosmsg": "^5.0.5",
    "@foxglove/rosmsg-serialization": "^2.0.4",
    "@foxglove/rosmsg2-serialization": "^3.0.3",
    "@mcap/core": "^2.2.0",
    "@mcap/nodejs": "^1.1.0",
    "@mcap/support": "^1.1.0"
  }
}
